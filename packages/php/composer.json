{
    "name": "vatvit/freshen",
    "description": "Stale-while-revalidate cache with stampede prevention (single-flight recompute + jittered TTLs).",
    "type": "library",
    "license": "MIT",
    "keywords": ["cache", "stale-while-revalidate", "swr", "stampede", "redis", "psr-6", "psr-16"],
    "require": {
        "php": ">=8.1",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0",
        "tedivm/stash": "v1.2.1"
    },
    "suggest": {
        "ext-redis": "To use the Redis-backed driver (Freshen\\Driver\\Redis)."
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Freshen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freshen\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
