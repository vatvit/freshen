{
    "name": "vatvit/freshen-symfony",
    "description": "Symfony bundle for Freshen — drop-in stale-while-revalidate cache with stampede prevention.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["cache", "stale-while-revalidate", "swr", "stampede", "symfony", "bundle", "freshen"],
    "require": {
        "php": ">=8.1",
        "vatvit/freshen-php": "^1.0",
        "psr/event-dispatcher": "^1.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "suggest": {
        "ext-redis": "To use the Redis-backed driver (Freshen\\Driver\\Redis)."
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Freshen\\Bridge\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freshen\\Bridge\\Symfony\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse"
    },
    "scripts-descriptions": {
        "test": "Run the unit suite (config + container wiring; no live backends).",
        "test:integration": "Boot a kernel against live Redis; needs ext-redis (see scripts/symfony-it.sh).",
        "analyse": "PHPStan level max."
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
